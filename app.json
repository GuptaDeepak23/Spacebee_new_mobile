{
  "expo": {
    "name": "Spacebee",
    "slug": "spacebee",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/spacebee.png",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1A4D8F"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/spacebee.png",
        "backgroundColor": "#1A4D8F"
      }
    },
    "plugins": [
      "expo-secure-store"
    ]
  }
}